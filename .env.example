PUBLIC_BASE_URL=
YOUCAM_API_BASE=https://yce-api-01.makeupar.com
YOUCAM_API_KEY=

# Seedance 2.0 video test
ARK_API_KEY=
SEEDANCE_API_BASE=https://ark.cn-beijing.volces.com
SEEDANCE_MODEL=doubao-seedance-2-0-260128
NEXT_PUBLIC_SEEDANCE_ASSET_IDS=
SEEDANCE_RESOLUTION=720p
SEEDANCE_RATIO=9:16
SEEDANCE_DURATION_SECONDS=4
SEEDANCE_GENERATE_AUDIO=false
SEEDANCE_WATERMARK=false
SEEDANCE_RETURN_LAST_FRAME=true

# Optional image/video reference input. For authorized real-person input only,
# set SEEDANCE_IMAGE_SUBJECT_TYPE=person and SEEDANCE_PERSON_INPUT_CONFIRMED=true.
SEEDANCE_IMAGE_URL=
SEEDANCE_IMAGE_ROLE=reference_image
SEEDANCE_IMAGE_SUBJECT_TYPE=
SEEDANCE_PERSON_INPUT_CONFIRMED=false
